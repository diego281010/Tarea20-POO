<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinica.tarea20mysql.controller.ParticipanteController">

    <top>
        <Label text="REGISTRO DE PARTICIPANTES DE NATACIÓN"
               BorderPane.alignment="CENTER"
               style="-fx-font-size:18px;
                      -fx-font-weight:bold;
                      -fx-padding:10;" />
    </top>

    <center>

        <VBox spacing="10">

            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <children>

                <HBox spacing="10">

                    <children>

                        <Label text="Cédula"/>

                        <TextField fx:id="txtCedula"
                                   prefWidth="150"/>

                        <Label text="Nombre"/>

                        <TextField fx:id="txtNombre"
                                   prefWidth="150"/>

                        <Label text="Apellido"/>

                        <TextField fx:id="txtApellido"
                                   prefWidth="150"/>

                    </children>

                </HBox>

                <HBox spacing="10">

                    <children>

                        <Label text="Edad"/>

                        <TextField fx:id="txtEdad"
                                   prefWidth="80"/>

                        <Label text="Correo"/>

                        <TextField fx:id="txtCorreo"
                                   prefWidth="250"/>

                    </children>

                </HBox>

                <HBox spacing="10">

                    <children>

                        <Label text="Estado Civil"/>

                        <ComboBox fx:id="cbEstadoCivil"
                                  prefWidth="180"/>

                        <Label text="Categoría"/>

                        <ComboBox fx:id="cbCategoria"
                                  prefWidth="180"/>

                    </children>

                </HBox>

                <HBox spacing="10">

                    <children>

                        <Label text="Jornada"/>

                        <RadioButton fx:id="rbMatutina"
                                     text="Matutina"/>

                        <RadioButton fx:id="rbVespertina"
                                     text="Vespertina"/>

                        <RadioButton fx:id="rbNocturna"
                                     text="Nocturna"/>

                    </children>

                </HBox>

                <VBox spacing="5">

                    <children>

                        <Label text="Observaciones"/>

                        <TextArea fx:id="txtObservaciones"
                                  prefHeight="80"/>

                    </children>

                </VBox>

                <HBox spacing="10">

                    <children>

                        <Button text="Guardar"
                                prefWidth="120"
                                onAction="#guardar"/>

                        <Button text="Actualizar"
                                prefWidth="120"
                                onAction="#actualizar"/>

                        <Button text="Eliminar"
                                prefWidth="120"
                                onAction="#eliminar"/>

                        <Button text="Limpiar"
                                prefWidth="120"
                                onAction="#limpiar"/>

                    </children>

                </HBox>

                <TableView fx:id="tablaParticipantes"
                           prefHeight="350">

                    <columns>

                        <TableColumn fx:id="colId"
                                     text="ID"
                                     prefWidth="60"/>

                        <TableColumn fx:id="colCedula"
                                     text="Cédula"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colNombre"
                                     text="Nombre"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colApellido"
                                     text="Apellido"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colEdad"
                                     text="Edad"
                                     prefWidth="80"/>

                        <TableColumn fx:id="colCorreo"
                                     text="Correo"
                                     prefWidth="180"/>

                        <TableColumn fx:id="colEstadoCivil"
                                     text="Estado Civil"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colJornada"
                                     text="Jornada"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colCategoria"
                                     text="Categoría"
                                     prefWidth="120"/>

                    </columns>

                </TableView>

            </children>

        </VBox>

    </center>

</BorderPane>